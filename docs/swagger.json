{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "Contacts API",
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "description": "API для роботи з контактами користувача (GoIT HW7).\n"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    },
    {
      "url": "https://nodejs-hw-mongodb-7-xof6.onrender.com"
    }
  ],
  "tags": [
    {
      "name": "Contacts",
      "description": "Операції з контактами"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "summary": "Отримати всі контакти користувача",
        "operationId": "getAllContacts",
        "description": "Повертає всі контакти, які належать авторизованому користувачу.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Номер сторінки"
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Кількість контактів на сторінці"
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "name"
            },
            "description": "Сортувати за полем"
          },
          {
            "name": "sortOrder",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "asc",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "description": "Порядок сортування"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Тип контакту (опціонально)"
          },
          {
            "name": "isFavourite",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Вибраний контакт (опціонально)"
          }
        ],
        "responses": {
          "200": {
            "description": "Список контактів користувача з пагінацією",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetContactsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некоректний запит",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Неавторизовано",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Contacts"
        ],
        "summary": "Створити новий контакт",
        "operationId": "createContact",
        "description": "Додає новий контакт для користувача.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "phoneNumber": {
                    "type": "string"
                  },
                  "contactType": {
                    "type": "string"
                  },
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Контакт створено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OneContactResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некоректні дані",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Неавторизовано",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contacts/{contactId}": {
      "get": {
        "tags": [
          "Contacts"
        ],
        "summary": "Отримати контакт за ID",
        "operationId": "getContactById",
        "description": "Повертає контакт по contactId. Потребує авторизації (Bearer Token).",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "contactId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Унікальний ідентифікатор контакту"
          }
        ],
        "responses": {
          "200": {
            "description": "Контакт знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OneContactResponse"
                }
              }
            }
          },
          "401": {
            "description": "Неавторизовано",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Контакт не знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Contacts"
        ],
        "summary": "Оновити контакт",
        "operationId": "updateContact",
        "description": "Оновлює дані контакту по contactId.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "contactId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Унікальний ідентифікатор контакту"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "phoneNumber": {
                    "type": "string"
                  },
                  "contactType": {
                    "type": "string"
                  },
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Контакт оновлено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OneContactResponse"
                }
              }
            }
          },
          "400": {
            "description": "Некоректний запит",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Неавторизовано",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Контакт не знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Contacts"
        ],
        "summary": "Видалити контакт",
        "operationId": "deleteContact",
        "description": "Видаляє контакт по contactId.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "contactId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Унікальний ідентифікатор контакту"
          }
        ],
        "responses": {
          "204": {
            "description": "Контакт видалено, відповіді немає"
          },
          "400": {
            "description": "Некоректний запит",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Неавторизовано",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Контакт не знайдено",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "1234567890abcdef"
          },
          "name": {
            "type": "string",
            "example": "test"
          },
          "phoneNumber": {
            "type": "string",
            "example": "+380501112233"
          },
          "contactType": {
            "type": "string",
            "example": "personal"
          },
          "userId": {
            "type": "string",
            "example": "abcdef1234567890"
          },
          "photo": {
            "type": "string",
            "example": ""
          },
          "__v": {
            "type": "integer",
            "example": 0
          }
        },
        "required": [
          "_id",
          "name",
          "phoneNumber",
          "contactType",
          "userId",
          "photo",
          "__v"
        ]
      },
      "GetContactsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "Successfully found contacts!"
          },
          "data": {
            "type": "object",
            "properties": {
              "contacts": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Contact"
                }
              },
              "page": {
                "type": "integer",
                "example": 1
              },
              "perPage": {
                "type": "integer",
                "example": 10
              },
              "total": {
                "type": "integer",
                "example": 37
              }
            }
          }
        },
        "required": [
          "status",
          "message",
          "data"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "example": 404
          },
          "message": {
            "type": "string",
            "example": "Contact not found"
          },
          "data": {
            "type": [
              "null",
              "object"
            ],
            "example": null
          }
        },
        "examples": {
          "notFound": {
            "summary": "Контакт не знайдено",
            "value": {
              "status": 404,
              "message": "Contact not found",
              "data": null
            }
          },
          "unauthorized": {
            "summary": "Неавторизовано",
            "value": {
              "status": 401,
              "message": "Authorization header missing or malformed",
              "data": null
            }
          },
          "forbidden": {
            "summary": "Токен невалідний чи протермінований",
            "value": {
              "status": 403,
              "message": "Refresh token is expired or invalid",
              "data": null
            }
          },
          "badRequest": {
            "summary": "Некоректний запит",
            "value": {
              "status": 400,
              "message": "Validation error",
              "data": null
            }
          }
        }
      },
      "OneContactResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "Successfully updated contact!"
          },
          "data": {
            "$ref": "#/components/schemas/Contact"
          }
        },
        "required": [
          "status",
          "message",
          "data"
        ]
      }
    }
  }
}